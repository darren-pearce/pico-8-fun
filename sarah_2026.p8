pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
p = {}

function _init()
 p = make_sarah(-4,80)
 move_sarah(p,60,p.y)
 dance_sarah(p,true)
end

function _update()
	update_sarah(p)
end

function _draw()
 cls()
	draw_sarah(p)
 rect(0,0,127,127,3)
 draw_main_text(0,8)
end
-->8
function make_sarah(x,y)
 local a = {}
 a.x = x
 a.y = y
 a.sprtab = {1,5}
 a.sprindex = 1
 a.sprtmr = 0
 a.sprtmrmax = 15
 a.destx = a.x
 a.desty = a.y
 return a
end

function update_sarah(a)
 local moving = false
	if (a.x < a.destx) then
	 a.x = a.x + 1
	 moving = true
	end
	if (a.x > a.destx) then
	 a.x = a.x - 1
	 moving = true
	end
	if (a.y < a.desty) then
	 a.y = a.y + 1
	 moving = true
	end
	if (a.y > a.desty) then
	 a.y = a.y - 1
	 moving = true
	end
	
	if moving or a.dancing then
	 a.sprtmr = a.sprtmr + 1
	 if a.sprtmr >= a.sprtmrmax then
	  a.sprtmr = 1
	  a.sprindex = a.sprindex + 1
	  if a.sprindex > count(a.sprtab) then
	   a.sprindex = 1
	  end
	 end
	else
	 a.sprindex = 1
	end
end

function draw_sarah(a)
 spr(a.sprtab[a.sprindex],a.x,a.y,4,4)
end

function move_sarah(a,x,y)
 a.destx = x
 a.desty = y
end

function dance_sarah(a,value)
 a.dancing = value
end
-->8
function draw_main_text(x,y)
	-- for each color
	-- (from pink -> white)
	
	for col = 14,7,-1 do
		
		-- for each letter
		for i=1,14 do
		
			-- t() is the same as time()
			t1 = t()*30 + i*4 - col*2
			
			-- position
			x2 = x+i*8     +cos(t1/90)*3
			y2 = y+(col-7)+cos(t1/50)*5
			pal(7,col)
			spr(63+i, x2, y2)
		end
 end
end
