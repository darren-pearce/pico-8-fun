pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
p = {}
state_initial=1
state_dancing=2
state_moving=3
state=state_initial
state_last=-1
state_timer=0
main_messagey=-20
message=1
messages={
"",
"happy 40th birthday",
"we love you mum",
"enjoy the balloons",
"have a fun day",
"enjoy your presents",
"you look beautiful",
"you are a fun mum",
"enjoy the music"
}
positions={
 {48,90},
 {90,30},
 {90,90},
 {20,30},
 {20,90},
 {90,30}
}
position=1

function _init()
 p = make_sarah(-40,90)
 local pos = positions[position]
 move_sarah(p,pos[1],pos[2])
 position+=1
end

function _update()
	update_sarah(p)
 state_timer+=1
	
 local firsttime = state ~= state_last
 state_last = state
 
 if state == state_initial then
  if not p.moving then
   state=state_dancing
   music(0)
  end
 elseif state == state_dancing then
  if firsttime then
   dance_sarah(p,true)
   state_timer=0
  else
   if main_messagey < 8 then
    main_messagey+=0.2
   elseif state_timer >= 30 * 5 then
    state=state_moving
    move_sarah(p,20,p.x)
    message+=1
    if message > #messages then message=2 end
   end
  end
 elseif state == state_moving then
  balloons_add()
  if firsttime then
		 local pos = positions[position]
		 move_sarah(p,pos[1],pos[2])
		 position+=1
		 if position > #positions then position=1 end
  else
	  if not p.moving then
	   state=state_dancing
	  end
  end
 end
 
 balloons_update()
end

function _draw()
 cls()
 --rect(0,0,127,127,3)
 
	draw_sarah(p)
	
 if state ~= state_initial then
  draw_main_text(0,main_messagey)
 end
 
 if state == state_initial then
 	
 elseif state == state_dancing then
  local str = messages[message]
  local width = print(str,0,-10)
  print(str,64-(width/2),74)
 elseif state == state_moving then
 
 end
 
 balloons_draw()
end
-->8
function make_sarah(x,y)
 local a = {}
 a.x = x
 a.y = y
-- a.movetab = {1,5}
-- a.dancetab = {9,132}
 a.movetab = {9,132}
 a.dancetab = {1,5}
 a.sprindex = 1
 a.spr=0
 a.sprtmr = 0
 a.sprtmrmax = 15
 a.destx = a.x
 a.desty = a.y
 a.dancing = false
 a.moving = false
 a.dxy=0.5
 return a
end

function update_sarah(a)
 a.moving = false
	if (a.x < a.destx) then
	 a.x+=a.dxy
	 a.moving = true
	end
	if (a.x > a.destx) then
	 a.x-=a.dxy
	 a.moving = true
	end
	if (a.y < a.desty) then
	 a.y+=a.dxy
	 a.moving = true
	end
	if (a.y > a.desty) then
	 a.y-=a.dxy
	 a.moving = true
	end
	
	if a.moving then
	 a.sprtmr+=1
	 if a.sprtmr >= a.sprtmrmax then
	  a.sprtmr = 1
	  a.sprindex+=1
	  if a.sprindex > #a.movetab then
	   a.sprindex = 1
	  end
	 end
	 a.spr=a.movetab[a.sprindex]
	elseif a.dancing then
	 a.sprtmr+=1
	 if a.sprtmr >= a.sprtmrmax then
	  a.sprtmr = 1
	  a.sprindex+=1
	  if a.sprindex > #a.dancetab then
	   a.sprindex = 1
	  end
	 end
	 a.spr=a.dancetab[a.sprindex]
	else
	 a.spr=a.movetab[1]
	end
end

function draw_sarah(a)
 spr(a.spr,a.x,a.y,4,4)
end

function move_sarah(a,x,y)
 a.destx = x
 a.desty = y
end

function dance_sarah(a,value)
 a.dancing = value
end
-->8
function draw_main_text(x,y)
	-- for each color
	-- (from pink -> white)
	
	for col = 14,7,-1 do
		
		-- for each letter
		for i=1,14 do
		
			-- t() is the same as time()
			t1 = t()*30 + i*4 - col*2
			
			-- position
			x2 = x+i*8     +cos(t1/90)*3
			y2 = y+(col-7)+cos(t1/50)*5
			pal(7,col)
			spr(63+i, x2, y2)
		end
 end
end
-->8
balloons={}
balloon_time=0

function balloons_add()
 if balloon_time == 0 then
  add(balloons,balloon_make(-16 +rnd(127),128))
  balloon_time = 5
 end
 balloon_time-=1
end

function balloons_update()
 foreach(balloons, balloon_update)
 foreach(balloons, balloons_delete)
end

function balloons_draw()
 foreach(balloons, balloon_draw)
end

function balloon_make(x,y)
local a = {}
a.x=x
a.y=y
a.dy= 0.3
a.colour=2+rnd(12)
return a
end

function balloon_update(a)
 a.y-=a.dy
 a.dy*=1.1
end

function balloon_draw(a)
 pal(7,a.colour)
 spr(128,a.x,a.y,4,4)
 pal()
end

function balloons_delete(a)
 if a.y < -100 then
  del(balloons,a)
 end
end
